{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for all app windows",
  "windows": ["main", "track-metadata"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "store:allow-get",
    "store:allow-set",
    "store:allow-delete",
    "store:allow-save",
    "store:allow-load",
    "deep-link:default",
    "deep-link:allow-get-current",
    "deep-link:allow-is-registered",
    "core:webview:allow-create-webview-window",
    "core:window:allow-create",
    "core:window:allow-set-size"
  ]
}
