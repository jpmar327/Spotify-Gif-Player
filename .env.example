# Spotify OAuth (PKCE — no client secret needed)
# Get your Client ID from https://developer.spotify.com/dashboard
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Giphy API key
# Get a free key at https://developers.giphy.com (create an app, choose "API" not "SDK")
VITE_GIPHY_API_KEY=your_giphy_api_key_here

# Last.fm API key (used as genre fallback when Spotify returns no genres)
# Get a free key at https://www.last.fm/api/account/create
VITE_LASTFM_API_KEY=your_lastfm_api_key_here
